rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for metofun admin roles
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.adminLevel == 'super_admin';
    }
    
    function isAgentAdmin() {
      return isAuthenticated() && request.auth.token.adminLevel == 'agent_admin';
    }
    
    function isShopAdmin() {
      return isAuthenticated() && request.auth.token.adminLevel == 'shop_admin';
    }
    
    function isAnyAdmin() {
      return isSuperAdmin() || isAgentAdmin() || isShopAdmin();
    }
    
    // Catch-all rule - require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}
