rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin check - must be authenticated and have an admin record
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Super admin check
    function isSuperAdmin() {
      return isAdmin() && 
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.level == 'super_admin';
    }

    // Shops - read: public, write: admin only
    match /shops/{shopId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Items - read: public, write: admin only
    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Attempts - read: admin only, write: admin only
    match /attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Admins - read: admin only, write: super_admin only
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // Settings - read: public, write: super_admin only
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Nomination items - read: public, write: admin only
    match /nominationItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Customer nominations - read: admin only, write: admin only
    match /customerNominations/{nominationId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
