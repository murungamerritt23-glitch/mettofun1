# Firebase Configuration
# Copy this to .env.local for local development, or set these in your hosting platform

# Required Firebase config - get these from your Firebase Project Settings
# Replace these with your actual Firebase project credentials
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Optional: Set to "true" to use Firebase emulators for local development
NEXT_PUBLIC_USE_EMULATORS=false

# Game Validation Secret
# Used for server-side game result validation (anti-cheat)
# IMPORTANT: In production, use a strong random string (min 32 characters)
GAME_VALIDATION_SECRET=your-secure-random-secret-at-least-32-chars

# Optional: API Key for additional validation endpoint protection
VALIDATION_API_KEY=your-api-key-for-validation-endpoint
